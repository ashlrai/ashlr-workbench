# ashlr-workbench environment template.
#
# Copy to `.env` and fill in. The workbench tools will source `.env` when run
# from the repo root. Never commit `.env` (it's in .gitignore).

# ─── Primary LLM (LM Studio) ──────────────────────────────────────────────────
# OpenAI-compatible endpoint exposed by LM Studio's "Start Server" button.
# Load qwen/qwen3-coder-30b in LM Studio before starting any agent.
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen/qwen3-coder-30b

# ─── Fallback LLM (Ollama) ────────────────────────────────────────────────────
# Optional. Used by Aider/Goose if you swap them via per-agent config.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:27b

# ─── Cloud fallbacks (optional) ───────────────────────────────────────────────
# Anthropic API key — used if you point any agent at Claude.
ANTHROPIC_API_KEY=

# xAI Grok — ashlrcode's default provider.
XAI_API_KEY=

# OpenAI — only if you opt in (the workbench is local-first by default).
OPENAI_API_KEY=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# OpenHands needs a PAT to clone/push from inside the container. Easiest: pull
# from gh-cli's stored token and export it before launching:
#   GITHUB_TOKEN="$(gh auth token)" aw start openhands
GITHUB_TOKEN=

# ─── ashlr-plugin location ────────────────────────────────────────────────────
# Override only if you keep the plugin somewhere other than ~/Desktop/ashlr-plugin.
ASHLR_PLUGIN_DIR=/Users/masonwyatt/Desktop/ashlr-plugin

# ─── External MCPs (ashlrcode) ────────────────────────────────────────────────
# Required if you use the supabase MCP server in agents/ashlrcode/settings.json.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# ─── UX ───────────────────────────────────────────────────────────────────────
# Set to anything non-empty to disable ANSI color in `aw` and the scripts.
# NO_COLOR=1
